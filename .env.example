# ── Postgres ────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=social
POSTGRES_PASSWORD=social
POSTGRES_SSLMODE=disable

# ── Redis ────────────────────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=

# ── NATS ─────────────────────────────────────────────────
NATS_URL=nats://localhost:4222
NATS_STREAM=SOCIAL

# ── MinIO ────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=social-media

# ── SMTP (Mailhog dev / Gmail prod) ──────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@social.local

# ── JWT ECDSA (ES256) ────────────────────────────────────
# Generate keys:
#   openssl ecparam -name prime256v1 -genkey -noout -out keys/private.pem
#   openssl ec -in keys/private.pem -pubout -out keys/public.pem
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# ── Observability ────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=localhost:4317

# ── Service ports ────────────────────────────────────────
USER_GRPC_PORT=50051
POST_GRPC_PORT=50052
CHAT_GRPC_PORT=50053
STORY_GRPC_PORT=50054
NOTIFICATION_GRPC_PORT=50055
GATEWAY_HTTP_PORT=8080
